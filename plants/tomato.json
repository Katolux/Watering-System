    "in_row": 50,
    "between_rows": 80
  },

  "support": {
    "needs_trellis": true,
    "height_cm_range": [120, 250],
    "notes": "Stake or trellis required for indeterminate types."
  },

  "roots": {
    "depth_cm_range": [40, 90],
    "type": "mixed"
  },

  "soil": {
    "preferred_textures": ["loam", "humus_rich"],
    "drainage": "good",
    "pH_range": [6.0, 6.8],
    "organic_matter": "likes_high",
    "notes": "Consistent moisture reduces blossom end rot."
  },

  "water_need": {
    "overall": "high",
    "stage_profile": {
      "establishment": "high",
      "vegetative": "medium",
      "flowering_fruiting": "high",
      "finish": "medium"
    }
  },

  "irrigation": {
    "sensitivity": "balanced",
    "mulch_helpful": true
  },

  "calendar": {
    "base": {
      "sow_indoors": {
        "weeks_relative_to_last_frost": [-10, -6],
        "months": [2, 3]
      },
      "transplant_out": {
        "weeks_relative_to_last_frost": [2, 6],
        "months": [5, 6]
      },
      "harvest": {
        "weeks_relative_to_last_frost": [12, 22],
        "months": [7, 8, 9, 10]
      }
    },
    "days_to_maturity_range": [60, 95]
  },

  "nutrition": {
    "feeder": "heavy",
    "emphasis": "K",
    "schedule_hint": "every_14_days",
    "notes": "Switch to potassium-rich feeding once flowering begins."
  },

  "care": {
    "pruning": {
      "required": true,
      "method": "suckers",
      "notes": "Remove side shoots for single-stem growth."
    },
    "pollination": {
      "type": "self",
      "aid_notes": "In greenhouse, gently shake flowers to improve fruit set."
    }
  },

  "companions": {
    "good": [
      { "plant_id": "basil", "reason": "Common pairing and space-efficient.", "confidence": "medium", "mechanism": "pest" },
      { "plant_id": "calendula", "reason": "Supports beneficial insects.", "confidence": "medium", "mechanism": "pollinator" },
      { "plant_id": "onion", "reason": "Allium scent may help pest confusion.", "confidence": "low", "mechanism": "pest" }
    ],
    "avoid": [
      { "plant_id": "potato", "reason": "Shared blight risk.", "confidence": "high", "mechanism": "disease" }
    ]
  },

